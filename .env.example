# note.com auto-poster configuration

# Gemini API Key (for thumbnail generation)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# (Optional) Path to note.com session state file
# Default: ~/.note-state.json
# NOTE_POST_MCP_STATE_PATH=

# (Optional) Browser operation timeout in ms
# Default: 180000 (3 minutes)
# NOTE_POST_MCP_TIMEOUT=180000
